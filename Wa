let current = 0;
let score = 0;
let answered = false;

const questionText = document.getElementById('questionText');
const optionsBox = document.getElementById('optionsBox');
const feedbackBox = document.getElementById('feedbackBox');
const feedbackTitle = document.getElementById('feedbackTitle');
const feedbackText = document.getElementById('feedbackText');
const nextBtn = document.getElementById('nextBtn');
const depthFill = document.getElementById('depthFill');
const depthLabel = document.getElementById('depthLabel');
const scoreLabel = document.getElementById('scoreLabel');
const layerName = document.getElementById('layerName');
const layerDot = document.getElementById('layerDot');
const quizScreen = document.getElementById('quizScreen');
const resultScreen = document.getElementById('resultScreen');
const finalScore = document.getElementById('finalScore');
const scoreMsg = document.getElementById('scoreMsg');
const restartBtn = document.getElementById('restartBtn');

const letters = ['ก','ข','ค','ง'];

function renderQuestion(){
  answered = false;
  const item = questions[current];
  const layer = layers[item.layer];

  depthLabel.textContent = `ข้อ ${current+1} / ${questions.length}`;
  depthFill.style.width = `${((current)/questions.length)*100}%`;
  scoreLabel.textContent = `ถูก ${score}`;
  layerName.textContent = layer.name;
  layerDot.style.background = layer.color;

  questionText.textContent = item.q;
  optionsBox.innerHTML = '';
  feedbackBox.className = 'feedback';
  feedbackBox.innerHTML = `<div class="feedback-title" id="feedbackTitle"></div><div id="feedbackText"></div>`;
  nextBtn.classList.remove('show');

  item.options.forEach((opt, idx)=>{
    const btn = document.createElement('button');
    btn.className = 'opt-btn';
    btn.innerHTML = `<span class="opt-letter">${letters[idx]}</span><span>${opt}</span>`;
    btn.addEventListener('click', ()=>selectAnswer(idx));
    optionsBox.appendChild(btn);
  });
}

function selectAnswer(idx){
  if(answered) return;
  answered = true;
  const item = questions[current];
  const buttons = optionsBox.querySelectorAll('.opt-btn');
  buttons.forEach(b=>b.disabled = true);

  const isCorrect = idx === item.correct;
  buttons[idx].classList.add(isCorrect ? 'correct' : 'wrong');
  if(!isCorrect){
    buttons[item.correct].classList.add('correct');
  }

  const fb = document.getElementById('feedbackBox');
  const ft = document.getElementById('feedbackTitle');
  const ftext = document.getElementById('feedbackText');

  if(isCorrect){
    score++;
    fb.classList.add('show','right');
    ft.textContent = '✓ ถูกต้อง';
    ftext.textContent = item.fact;
  } else {
    fb.classList.add('show','wrong');
    ft.textContent = '✗ ไม่ถูกต้อง';
    ftext.textContent = item.explainWrong[idx] || 'คำตอบนี้ไม่ตรงกับหลักความจริงทางวิทยาศาสตร์';
  }

  scoreLabel.textContent = `ถูก ${score}`;
  nextBtn.classList.add('show');
  nextBtn.textContent = current === questions.length-1 ? 'ดูผลลัพธ์ →' : 'ข้อต่อไป →';
}

nextBtn.addEventListener('click', ()=>{
  current++;
  if(current >= questions.length){
    showResult();
  } else {
    renderQuestion();
  }
});

function showResult(){
  quizScreen.classList.add('hide');
  resultScreen.classList.add('show');
  depthFill.style.width = '100%';
  depthLabel.textContent = `ข้อ ${questions.length} / ${questions.length}`;

  finalScore.textContent = `${score}/${questions.length}`;
  let msg = '';
  if(score === questions.length){
    msg = 'เจาะทะลุถึงใจกลางโลกได้สมบูรณ์แบบ! คุณเข้าใจโครงสร้างโลกทุกชั้นอย่างแท้จริง';
  } else if(score >= 7){
    msg = 'ผ่านชั้นแมนเทิลและแกนโลกได้อย่างมั่นใจ ความเข้าใจของคุณแน่นมาก';
  } else if(score >= 4){
    msg = 'ผ่านเปลือกโลกได้สบาย แต่บางชั้นลึกๆยังต้องทำความเข้าใจเพิ่ม ลองอ่านคำอธิบายอีกครั้งดูนะ';
  } else {
    msg = 'การเจาะโลกยังติดอยู่แถวพื้นผิว ลองทบทวนคำอธิบายแล้วเจาะใหม่อีกครั้ง';
  }
  scoreMsg.textContent = msg;
}

restartBtn.addEventListener('click', ()=>{
  current = 0;
  score = 0;
  resultScreen.classList.remove('show');
  quizScreen.classList.remove('hide');
  renderQuestion();
});

renderQuestion();
</script>

