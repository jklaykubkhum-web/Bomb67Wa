<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ตัดขวางโลก — เกมตอบคำถามโครงสร้างโลก</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=JetBrains+Mono:wght@400;500;700&display=swap');

  :root{
    --crust: #c9a36a;
    --mantle: #b5471f;
    --outer-core: #ff7a1a;
    --inner-core: #ffe27a;
    --ink: #fff5e6;
    --ink-dim: #ffd9ad;
    --panel: rgba(15,8,4,0.72);
    --good: #6ee7a0;
    --bad: #ff6b6b;
  }

  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}

  body{
    min-height:100vh;
    font-family:'Space Grotesk', sans-serif;
    color:var(--ink);
    background: radial-gradient(circle at 50% 100%, var(--inner-core) 0%, var(--outer-core) 18%, var(--mantle) 45%, #5a2410 72%, #2a1208 100%);
    overflow-x:hidden;
    position:relative;
  }

  /* layered earth cross-section background, fixed */
  .earth-bg{
    position:fixed;
    inset:0;
    z-index:-2;
    background:
      radial-gradient(circle at 50% 140%, #ffe27a 0%, #ff7a1a 18%, #c8430f 38%, #7a2b12 58%, #3c160a 78%, #1a0a05 100%);
  }
  .earth-bg::before{
    content:"";
    position:absolute; inset:0;
    background-image:
      repeating-radial-gradient(circle at 50% 140%,
        rgba(255,255,255,0.035) 0px,
        rgba(255,255,255,0.035) 2px,
        transparent 2px,
        transparent 14px);
    mix-blend-mode:overlay;
  }
  .core-glow{
    position:fixed;
    left:50%; bottom:-30vh;
    width:70vmax; height:70vmax;
    transform:translateX(-50%);
    background:radial-gradient(circle, rgba(255,226,122,0.9) 0%, rgba(255,122,26,0.55) 30%, transparent 65%);
    filter:blur(10px);
    z-index:-1;
    animation: pulse 5s ease-in-out infinite;
  }
  @keyframes pulse{
    0%,100%{opacity:0.85; transform:translateX(-50%) scale(1);}
    50%{opacity:1; transform:translateX(-50%) scale(1.06);}
  }

  .wrap{
    max-width:680px;
    margin:0 auto;
    padding:32px 20px 80px;
    position:relative;
    z-index:1;
  }

  header{
    text-align:center;
    margin-bottom:28px;
  }
  .eyebrow{
    font-family:'JetBrains Mono', monospace;
    font-size:12px;
    letter-spacing:0.18em;
    text-transform:uppercase;
    color:var(--ink-dim);
    opacity:0.85;
    margin-bottom:8px;
  }
  h1{
    font-size:clamp(28px,7vw,42px);
    font-weight:700;
    margin:0 0 6px;
    letter-spacing:-0.01em;
    text-shadow:0 2px 20px rgba(0,0,0,0.4);
  }
  .sub{
    font-size:14px;
    color:var(--ink-dim);
    opacity:0.9;
  }

  /* depth gauge */
  .depth-gauge{
    display:flex;
    align-items:center;
    gap:10px;
    margin:20px 0 28px;
    font-family:'JetBrains Mono', monospace;
    font-size:11px;
    color:var(--ink-dim);
  }
  .depth-track{
    flex:1;
    height:6px;
    border-radius:4px;
    background:rgba(0,0,0,0.35);
    overflow:hidden;
    position:relative;
  }
  .depth-fill{
    height:100%;
    background:linear-gradient(90deg, var(--crust), var(--inner-core));
    width:0%;
    transition:width 0.5s ease;
  }

  .panel{
    background:var(--panel);
    border:1px solid rgba(255,200,140,0.18);
    border-radius:16px;
    padding:28px 24px;
    backdrop-filter:blur(6px);
    box-shadow:0 20px 60px rgba(0,0,0,0.4);
  }

  .layer-tag{
    display:inline-flex;
    align-items:center;
    gap:6px;
    font-family:'JetBrains Mono', monospace;
    font-size:11px;
    letter-spacing:0.08em;
    text-transform:uppercase;
    padding:5px 10px;
    border-radius:20px;
    background:rgba(255,255,255,0.08);
    color:var(--ink-dim);
    margin-bottom:16px;
  }
  .layer-dot{width:8px; height:8px; border-radius:50%; background:var(--inner-core);}

  .question-text{
    font-size:clamp(18px,4.2vw,22px);
    font-weight:500;
    line-height:1.5;
    margin-bottom:22px;
  }

  .options{
    display:flex;
    flex-direction:column;
    gap:10px;
  }
  .opt-btn{
    text-align:left;
    padding:14px 16px;
    border-radius:10px;
    border:1px solid rgba(255,200,140,0.25);
    background:rgba(0,0,0,0.25);
    color:var(--ink);
    font-family:'Space Grotesk', sans-serif;
    font-size:15px;
    cursor:pointer;
    transition:border-color 0.2s, background 0.2s, transform 0.1s;
    display:flex;
    gap:10px;
  }
  .opt-btn:hover:not(:disabled){
    border-color:rgba(255,200,140,0.6);
    background:rgba(0,0,0,0.4);
  }
  .opt-btn:active:not(:disabled){transform:scale(0.99);}
  .opt-btn:disabled{cursor:default;}
  .opt-letter{
    font-family:'JetBrains Mono', monospace;
    opacity:0.6;
    flex-shrink:0;
  }
  .opt-btn.correct{
    border-color:var(--good);
    background:rgba(110,231,160,0.15);
  }
  .opt-btn.wrong{
    border-color:var(--bad);
    background:rgba(255,107,107,0.15);
  }

  .feedback{
    margin-top:18px;
    padding:16px 18px;
    border-radius:10px;
    font-size:14px;
    line-height:1.6;
    display:none;
  }
  .feedback.show{display:block; animation:fadeIn 0.3s ease;}
  .feedback.right{background:rgba(110,231,160,0.12); border:1px solid rgba(110,231,160,0.35);}
  .feedback.wrong{background:rgba(255,107,107,0.12); border:1px solid rgba(255,107,107,0.35);}
  .feedback-title{
    font-weight:700;
    margin-bottom:4px;
    display:flex;
    align-items:center;
    gap:6px;
  }
  @keyframes fadeIn{from{opacity:0; transform:translateY(6px);} to{opacity:1; transform:translateY(0);}}

  .next-btn{
    margin-top:18px;
    width:100%;
    padding:14px;
    border-radius:10px;
    border:none;
    background:linear-gradient(90deg, var(--outer-core), var(--inner-core));
    color:#1a0a05;
    font-family:'Space Grotesk', sans-serif;
    font-weight:700;
    font-size:15px;
    cursor:pointer;
    display:none;
  }
  .next-btn.show{display:block;}
  .next-btn:hover{filter:brightness(1.08);}

  /* results screen */
  .result-screen{display:none; text-align:center;}
  .result-screen.show{display:block;}
  .score-num{
    font-family:'JetBrains Mono', monospace;
    font-size:64px;
    font-weight:700;
    line-height:1;
    margin:6px 0;
    text-shadow:0 0 30px rgba(255,200,120,0.6);
  }
  .score-label{font-size:14px; color:var(--ink-dim);}
  .score-msg{margin:18px 0 26px; font-size:16px; line-height:1.6;}
  .restart-btn{
    padding:14px 28px;
    border-radius:10px;
    border:1px solid rgba(255,200,140,0.4);
    background:rgba(255,255,255,0.08);
    color:var(--ink);
    font-family:'Space Grotesk', sans-serif;
    font-weight:700;
    font-size:15px;
    cursor:pointer;
  }
  .restart-btn:hover{background:rgba(255,255,255,0.15);}

  .quiz-screen{display:block;}
  .quiz-screen.hide{display:none;}

  footer.note{
    text-align:center;
    font-size:11px;
    color:var(--ink-dim);
    opacity:0.6;
    margin-top:24px;
    font-family:'JetBrains Mono', monospace;
  }
</style>
</head>
<body>

<div class="earth-bg"></div>
<div class="core-glow"></div>

<div class="wrap">
  <header>
    <div class="eyebrow">เจาะลึกถึงแกนโลก</div>
    <h1>ตัดขวางโลก</h1>
    <div class="sub">เกมตอบคำถามวิทยาศาสตร์ · โครงสร้างโลก 10 ข้อ</div>
  </header>

  <div class="depth-gauge">
    <span id="depthLabel">ข้อ 1 / 10</span>
    <div class="depth-track"><div class="depth-fill" id="depthFill"></div></div>
    <span id="scoreLabel">ถูก 0</span>
  </div>

  <div class="quiz-screen" id="quizScreen">
    <div class="panel">
      <div class="layer-tag"><span class="layer-dot" id="layerDot"></span><span id="layerName">เปลือกโลก</span></div>
      <div class="question-text" id="questionText"></div>
      <div class="options" id="optionsBox"></div>
      <div class="feedback" id="feedbackBox">
        <div class="feedback-title" id="feedbackTitle"></div>
        <div id="feedbackText"></div>
      </div>
      <button class="next-btn" id="nextBtn">ข้อต่อไป →</button>
    </div>
  </div>

  <div class="result-screen" id="resultScreen">
    <div class="panel">
      <div class="layer-tag"><span class="layer-dot"></span>สรุปผลการเจาะโลก</div>
      <div class="score-label">คะแนนของคุณ</div>
      <div class="score-num" id="finalScore">0/10</div>
      <div class="score-msg" id="scoreMsg"></div>
      <button class="restart-btn" id="restartBtn">เจาะใหม่อีกครั้ง</button>
    </div>
  </div>

  <footer class="note">เปลือกโลก → แมนเทิล → แกนโลกชั้นนอก → แกนโลกชั้นใน</footer>
</div>

<script>
const layers = [
  {name:"เปลือกโลก", color:"#c9a36a"},
  {name:"แมนเทิล", color:"#ff7a1a"},
  {name:"แกนโลกชั้นนอก", color:"#ffae4a"},
  {name:"แกนโลกชั้นใน", color:"#ffe27a"}
];

const questions = [
  {
    layer:0,
    q:"ชั้นที่อยู่ชั้นนอกสุดของโลก ซึ่งเป็นที่ตั้งของทวีปและพื้นมหาสมุทร เรียกว่าอะไร",
    options:["เปลือกโลก (Crust)","แมนเทิล (Mantle)","แกนโลกชั้นนอก (Outer Core)","ลิโทสเฟียร์ (Lithosphere)"],
    correct:0,
    explainWrong:{
      1:"แมนเทิลคือชั้นที่อยู่ใต้เปลือกโลกลงไป ไม่ใช่ชั้นนอกสุด เปลือกโลกต่างหากที่เป็นชั้นบางๆด้านบนที่เราอาศัยอยู่",
      2:"แกนโลกชั้นนอกอยู่ลึกลงไปหลายพันกิโลเมตร เป็นของเหลวร้อนจัด ไม่ใช่ชั้นที่เราเดินอยู่บนนั้น",
      3:"ลิโทสเฟียร์เป็นคำที่รวมเปลือกโลกกับส่วนบนของแมนเทิลที่แข็งเข้าด้วยกัน จึงไม่ใช่คำตอบที่ตรงที่สุดสำหรับ 'ชั้นนอกสุด' เพียงอย่างเดียว"
    },
    fact:"เปลือกโลกบางมากเมื่อเทียบกับทั้งโลก หนาเฉลี่ยเพียง 5-70 กิโลเมตร เหมือนเปลือกไข่ที่บางเมื่อเทียบกับทั้งฟอง"
  },
  {
    layer:0,
    q:"เปลือกโลกใต้มหาสมุทรกับเปลือกโลกที่เป็นทวีป ต่างกันอย่างไร",
    options:[
      "เปลือกทวีปหนากว่าและความหนาแน่นน้อยกว่าเปลือกมหาสมุทร",
      "เปลือกมหาสมุทรหนากว่าและความหนาแน่นน้อยกว่าเปลือกทวีป",
      "ทั้งสองชนิดมีความหนาและความหนาแน่นเท่ากันทุกประการ",
      "เปลือกมหาสมุทรประกอบด้วยหินแกรนิตเป็นหลัก"
    ],
    correct:0,
    explainWrong:{
      1:"สลับกัน เปลือกมหาสมุทรจริงๆบางกว่าเปลือกทวีป แต่มีความหนาแน่นมากกว่า เพราะส่วนใหญ่เป็นหินบะซอลต์",
      2:"ทั้งสองชนิดต่างกันทั้งความหนาและองค์ประกอบ เปลือกทวีปหนาประมาณ 30-70 กม. ส่วนเปลือกมหาสมุทรหนาเพียง 5-10 กม.",
      3:"หินแกรนิตเป็นองค์ประกอบหลักของเปลือกทวีป ไม่ใช่เปลือกมหาสมุทรซึ่งเป็นหินบะซอลต์เป็นหลัก"
    },
    fact:"เปลือกทวีปมีความหนาแน่นน้อยกว่า จึงลอยตัวสูงกว่าเปลือกมหาสมุทรเมื่อเทียบกับชั้นแมนเทิลด้านล่าง"
  },
  {
    layer:1,
    q:"ชั้นแมนเทิลของโลกมีสถานะอย่างไร",
    options:[
      "เป็นของแข็งแต่ยืดหยุ่นจนไหลตัวได้ช้าๆเหมือนของหนืด",
      "เป็นของเหลวร้อนจัดเหมือนลาวาทั้งชั้น",
      "เป็นแก๊สร้อนความดันสูง",
      "เป็นของแข็งแกร่งที่ไม่เคลื่อนที่เลย"
